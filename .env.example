# =============================================================================
#  mcp-ntis 환경설정
# =============================================================================
#  두 가지 모드 중 하나를 선택해서 채워주세요.
#
#  ┌─────────────────────────────────────────────────────────────────────────┐
#  │ 【모드 A】 게이트웨이 사용자 (NTIS·ScienceON·DataON 키 발급 없이 사용)        │
#  │   - NTIS_GATEWAY_URL + NTIS_GATEWAY_API_KEY 두 줄만 채우면 끝               │
#  │   - 게이트웨이 운영자가 알려준 URL과 토큰을 사용                              │
#  │   - 개별 NTIS/ScienceON/DataON 키 칸은 모두 비워두세요                        │
#  └─────────────────────────────────────────────────────────────────────────┘
#  ┌─────────────────────────────────────────────────────────────────────────┐
#  │ 【모드 B】 게이트웨이 운영자 (직접 NTIS/ScienceON/DataON 키 신청·보유)        │
#  │   - 아래 모든 발급 키를 채워주세요                                          │
#  │   - NTIS_GATEWAY_URL 은 비워둡니다 (게이트웨이 자기 자신은 프록시 X)         │
#  │   - GATEWAY_API_KEY (자체 인증) 발급 → 사용자에게 배포                        │
#  └─────────────────────────────────────────────────────────────────────────┘
# =============================================================================


# ▼▼▼▼▼  모드 A: 게이트웨이 사용자  ▼▼▼▼▼
#
# 운영자에게 받은 URL/토큰을 채우세요. 두 줄만 채워도 MCP·챗봇 작동 OK.
# 채우는 순간 server.py 가 자동 게이트웨이 프록시 모드로 부팅합니다.
NTIS_GATEWAY_URL=
NTIS_GATEWAY_API_KEY=


# ▼▼▼▼▼  공통: LLM (어느 모드든 챗봇 사용 시 필요)  ▼▼▼▼▼
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929


# ▼▼▼▼▼  모드 B: 게이트웨이 운영자 (또는 단독 사용자)  ▼▼▼▼▼
# 아래는 모드 B(또는 게이트웨이 없이 직접 호출)일 때만 필요.
# 모드 A 사용자는 모두 비워두세요.

# Required (모드 B): NTIS 인증키 (승인된 발급키)
NTIS_API_KEY=

# Optional: 신규 API 키 (이슈/용어/분류코드용)
NTIS_NEW_API_KEY=

# Optional: 기관약어 (분류추천 API에 필요)
NTIS_ORG_CD=

# Optional: 사용자 ID
NTIS_USER_ID=

# Optional: NTIS 응답 캐시 TTL (시간)
NTIS_CACHE_TTL_HOURS=24

# ScienceON API (선택) — KISTI ScienceON OpenAPI Gateway
# 세 변수가 모두 설정되면 ScienceON 17개 도구 자동 활성화
# https://scienceon.kisti.re.kr/apigateway/main/mainForm.do 에서 신청
SCIENCEON_CLIENT_ID=
SCIENCEON_API_KEY=
SCIENCEON_MAC=AA-BB-CC-DD-EE-FF

# DataON API (선택) — KISTI 국가연구데이터플랫폼
# 검색용·상세조회용 별도 발급
DATAON_API_KEY=
DATAON_DETAIL_API_KEY=

# (모드 B 운영자만) 게이트웨이 자체 인증 키 — 사용자에게 배포할 토큰
# `openssl rand -hex 32` 로 생성. 빈 값이면 인증 비활성화 (개발용).
GATEWAY_API_KEY=


# ▼▼▼▼▼  MCP 서버 동작 설정  ▼▼▼▼▼
LOG_LEVEL=INFO
TRANSPORT=stdio
