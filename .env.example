# Required: NTIS 인증키 (승인된 발급키)
NTIS_API_KEY=your_api_key_here

# Optional: 신규 API 키 (이슈/용어/분류코드용)
NTIS_NEW_API_KEY=

# Optional: 기관약어 (분류추천 API에 필요)
NTIS_ORG_CD=

# Optional: 사용자 ID
NTIS_USER_ID=

# Optional: 캐시 TTL (시간 단위)
NTIS_CACHE_TTL_HOURS=24

# MCP 서버 설정
LOG_LEVEL=INFO
TRANSPORT=stdio

# Claude API (Streamlit DeepAgent 챗봇용)
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ScienceON API (선택) — KISTI ScienceON OpenAPI Gateway
# 세 변수가 모두 설정되면 ScienceON 24개 도구 자동 활성화
# https://scienceon.kisti.re.kr/apigateway/main/mainForm.do 에서 신청
SCIENCEON_CLIENT_ID=
SCIENCEON_API_KEY=
SCIENCEON_MAC=AA-BB-CC-DD-EE-FF

# DeepAgent 챗봇이 외부 REST 게이트웨이를 통해 도구 호출하도록 전환 (선택)
# 비워두면 in-process로 mcp_ntis를 직접 import (기존 동작).
# 설정하면 NTIS/ScienceON 키 없이도 챗봇 실행 — 게이트웨이가 호출 대행.
# 운영자에게 받은 URL/API key를 채우세요.
NTIS_GATEWAY_URL=
NTIS_GATEWAY_API_KEY=

# (게이트웨이 운영자 측만 사용) 게이트웨이 자체 인증 키 발급.
# `openssl rand -hex 32` 로 생성 권장. 빈 값이면 인증 비활성화(개발용).
GATEWAY_API_KEY=

# DataON API (선택) — KISTI DataON 연구데이터 플랫폼
# 신청·발급은 DataON OpenAPI 가이드 참조
DATAON_API_KEY=
